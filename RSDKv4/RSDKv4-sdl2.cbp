<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="RSDKv4-sdl2" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug x64">
				<Option output="../build/x64/Debug/SDL2/RSDKv4_64" prefix_auto="1" extension_auto="1" />
				<Option object_output="../build/x64/Debug/Intermediate/SDL2/" />
				<Option deps_output="../build/x64/Debug/SDL2/" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add option="-DRETRO_USE_SDL2" />
					<Add option="-DRETRO_USING_OPENGL=0" />
					<Add option="-D_CRT_SECURE_NO_WARNINGS" />
					<Add option="-DUSE_SW_REN" />
					<Add option="-D_DEBUG" />
					<Add option="-D_CONSOLE" />
					<Add directory="../RSDKv4/" />
					<Add directory="../RSDKv4/NativeObjects/" />
					<Add directory="../dependencies/all/asio/asio/include/" />
					<Add directory="../dependencies/all/stb-image/" />
					<Add directory="../dependencies/all/tinyxml2/" />
					<Add directory="../dependencies/windows/SDL2/include/" />
					<Add directory="../dependencies/windows/libogg/include/" />
					<Add directory="../dependencies/windows/libvorbis/include/" />
					<Add directory="../dependencies/windows/glew/include/" />
				</Compiler>
				<Linker>
					<Add library="SDL2.lib" />
					<Add library="SDL2main.lib" />
					<Add library="libogg.lib" />
					<Add library="libvorbis_static.lib" />
					<Add library="libvorbisfile_static.lib" />
					<Add library="Opengl32.lib" />
					<Add library="glu32.lib" />
					<Add library="glew32.lib" />
					<Add library="Shell32.lib" />
					<Add directory="../dependencies/windows/SDL2/lib/$(PlatformTargetAsMSBuildArchitecture)/" />
					<Add directory="../dependencies/windows/libvorbis/win32/VS2010/x64/Debug/" />
					<Add directory="../dependencies/windows/libogg/win32/VS2015/x64/Debug/" />
					<Add directory="../dependencies/windows/glew/lib/Release/x64/" />
				</Linker>
				<ExtraCommands>
					<Add after='copy /Y &quot;../dependencies/windows/SDL2/lib/$(PlatformTargetAsMSBuildArchitecture)/SDL2.dll&quot; &quot;../build/x64/Debug/SDL2/&quot;&#x0A;copy /Y &quot;../dependencies/windows/glew/bin/Release/x64/glew32.dll&quot; &quot;../build/x64/Debug/SDL2/&quot;' />
				</ExtraCommands>
			</Target>
